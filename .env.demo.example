# Demo stack environment (copy to .env.demo on the VPS if missing).
# Used by docker-compose.demo.yml — separate from production .env.

SECRET_KEY=change-me-demo-secret-key
DEMO_MODE=true
DEMO_WATERMARK=DEMO
DOCX_WATERMARK=DEMO
DOCX_FILL_DEMO_WHEN_EMPTY=true

DEMO_POSTGRES_USER=medinsight
DEMO_POSTGRES_PASSWORD=demo_secure_password
DEMO_POSTGRES_DB=medinsight_demo
DEMO_APP_PORT=8001

FRONTEND_URL=https://demo.fileguardian.com.ru
CORS_ORIGINS=https://demo.fileguardian.com.ru,http://localhost:8001

REDIS_CACHE_ENABLED=true
ENCRYPTION_ENABLED=true
TENANT_MODE=true
TELEGRAM_BOT_ENABLED=false
BILLING_ENABLED=false
APPOINTMENTS_ENABLED=true

SUPER_ADMIN_EMAIL=admin@medinsight.com
SUPER_ADMIN_PASSWORD=change_me_super_admin
DEFAULT_TENANT_NAME=Default Clinic
DEFAULT_TENANT_SUBDOMAIN=default

STORAGE_PATH=/app/storage
DICOM_STORAGE_PATH=/app/storage/dicom
CHROMA_EMBEDDINGS_ENABLED=false
OTEL_ENABLED=false
