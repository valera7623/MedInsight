<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Прогноз рисков</title>
    <style>
        body { font-family: Helvetica, 'DejaVu Sans', sans-serif; }
        .header { text-align: center; border-bottom: 2px solid #dc2626; padding-bottom: 20px; }
        .header h1 { color: #dc2626; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #fecaca; padding: 10px; }
        th { background: #fef2f2; }
        .high { color: #dc2626; font-weight: bold; }
        .footer { text-align: center; font-size: 12px; color: #94a3b8; margin-top: 40px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ title | default('Прогноз рисков') }}</h1>
        <p>{{ patient.last_name }} {{ patient.first_name }} | {{ generated_at }}</p>
    </div>
    <table>
        <thead><tr><th>Тип прогноза</th><th>Риск (%)</th></tr></thead>
        <tbody>
        {% for prediction in predictions %}
            <tr><td>{{ prediction.type }}</td><td>{{ prediction.risk }}%</td></tr>
        {% else %}
            <tr><td colspan="2">Прогнозы отсутствуют</td></tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="footer"><p>MedInsight AI Risk Prediction — не является медицинским заключением</p></div>
</body>
</html>
