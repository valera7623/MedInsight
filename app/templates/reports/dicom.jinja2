<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>DICOM-отчёт</title>
    <style>
        body { font-family: Helvetica, 'DejaVu Sans', sans-serif; }
        .header { text-align: center; border-bottom: 2px solid #2563eb; padding-bottom: 20px; }
        .header h1 { color: #2563eb; }
        .section { margin: 20px 0; }
        .section h2 { color: #1e293b; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; }
        .row { margin: 10px 0; }
        .label { font-weight: bold; width: 200px; display: inline-block; }
        .footer { text-align: center; font-size: 12px; color: #94a3b8; margin-top: 50px; }
        img { max-width: 100%; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>DICOM-отчёт</h1>
        <p>Исследование: {{ dicom_study.study_description }}</p>
        <p>Пациент: {{ patient.last_name }} {{ patient.first_name }}</p>
    </div>

    <div class="section">
        <h2>Метаданные</h2>
        <div class="row"><span class="label">Модальность:</span> {{ dicom_study.modality }}</div>
        <div class="row"><span class="label">Область:</span> {{ dicom_study.body_part }}</div>
        <div class="row"><span class="label">Серий:</span> {{ dicom_study.num_series }}</div>
        <div class="row"><span class="label">Кадров:</span> {{ dicom_study.num_instances }}</div>
        {% if dicom_study.impression %}<div class="row"><span class="label">Заключение:</span> {{ dicom_study.impression }}</div>{% endif %}
    </div>

    <div class="section">
        <h2>Находки</h2>
        <ul>{% for finding in findings %}<li>{{ finding }}</li>{% else %}<li>Нет данных</li>{% endfor %}</ul>
    </div>

    <div class="section">
        <h2>Изображения</h2>
        {% for image in images %}<img src="{{ image }}" alt="DICOM frame" />{% else %}<p>Изображения недоступны</p>{% endfor %}
    </div>

    <div class="footer"><p>Сгенерировано в MedInsight | {{ generated_at }}</p></div>
</body>
</html>
