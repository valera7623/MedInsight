SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./medinsight.db
# Docker (app + celery share this path via volume):
# DATABASE_URL=sqlite:////app/data/medinsight.db
STORAGE_PATH=./storage
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
SPACY_MODEL=ru_core_news_lg
APP_PORT=8000
# DOMAIN is used by Traefik (production) for the HTTPS router + Let's Encrypt cert
DOMAIN=fileguardian.com.ru
ACME_EMAIL=admin@fileguardian.com.ru

# Phase 2: Celery + GPT (ProxyAPI)
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
OPENAI_API_KEY=ваш_ключ_из_ProxyAPI
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Phase 3: Multi-tenancy + Encryption
TENANT_MODE=true
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=
ENCRYPTION_KEY_PATH=secrets/encryption_key.txt
SUPER_ADMIN_EMAIL=admin@medinsight.com
SUPER_ADMIN_PASSWORD=change_me_super_admin
DEFAULT_TENANT_NAME=Default Clinic
DEFAULT_TENANT_SUBDOMAIN=default

# Phase 4: Self-Healing RAG
SELF_HEALING_ENABLED=true
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.75
MAX_RETRY_ATTEMPTS=2

# Phase 4: Webhooks
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_SECONDS=2
WEBHOOK_FAILURE_DEACTIVATE_THRESHOLD=5
WEBHOOK_PUBLIC_BASE_URL=

# Phase 4: Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_yyy
STRIPE_SUCCESS_URL=https://your-domain/payment/success
STRIPE_CANCEL_URL=https://your-domain/payment/cancel

# Phase 4: ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL_SUCCESS=https://your-domain/payment/success
YOOKASSA_RETURN_URL_CANCEL=https://your-domain/payment/cancel

# Phase 4: Plan limits + prices (kopecks for RUB, cents for USD)
FREEMIUM_ANALYSIS_LIMIT=5
PRO_ANALYSIS_LIMIT=100
ENTERPRISE_ANALYSIS_LIMIT=999999
PRO_PRICE_RUB=199000
PRO_PRICE_USD=1999
ENTERPRISE_PRICE_RUB=999000
ENTERPRISE_PRICE_USD=9999

# Главный выключатель биллинга. false = тестовый режим:
# лимиты анализов отключены, оплата (checkout) недоступна.
BILLING_ENABLED=true

# Phase 7: Excel export
EXPORT_MAX_ROWS=10000
EXPORT_MAX_COLUMNS=50
EXPORT_TEMP_DIR=./storage/exports

# Phase 8: Backup & Restore
BACKUP_ENABLED=true
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_RETENTION_MONTHS=12
BACKUP_SCHEDULE_FULL=0 2 * * *
BACKUP_SCHEDULE_DB=0 * * * *
BACKUP_SCHEDULE_CLEANUP=0 3 * * *
BACKUP_MAX_SIZE_MB=10240
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_KEY=
BACKUP_ALERT_MAX_AGE_HOURS=48
# Optional Telegram alerting for backup health (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase 10: Telegram bot (user notifications)
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_WEBHOOK_URL=
TELEGRAM_BOT_WEBHOOK_SECRET=
TELEGRAM_BOT_COMMAND_RATE_LIMIT=30
TELEGRAM_LINK_CODE_TTL=600

# Phase 11: Dark mode default for new users (light | dark | system)
DEFAULT_THEME=light

# Phase 12: DICOM medical imaging
DICOM_ENABLED=true
DICOM_MAX_FILE_SIZE_MB=500
DICOM_STORAGE_PATH=./storage/dicom
DICOM_THUMBNAIL_SIZE=256x256
DICOM_VIEWER_MAX_SIZE=1024
DICOM_PNG_COMPRESS_LEVEL=1
DICOM_ZIP_MAX_SIZE_MB=2048
DICOM_ZIP_TEMP_DIR=./temp/dicom_zip
DICOM_ZIP_MAX_FILES=5000
DICOM_ZIP_TASK_TIMEOUT_SEC=1800

# Phase 12c: DICOM annotations (image markup)
DICOM_ANNOTATIONS_ENABLED=true
DICOM_ANNOTATIONS_AUTO_SAVE_DELAY_MS=500
DICOM_ANNOTATIONS_MAX_PER_FRAME=100
DICOM_ANNOTATIONS_HISTORY_LIMIT=50
DICOM_ANNOTATIONS_EXPORT_MAX_FRAMES=100

# Phase 12d: DICOM 3D volume rendering (MPR + VR)
DICOM_3D_ENABLED=true
DICOM_3D_CACHE_SIZE_GB=10
DICOM_3D_MAX_VOLUME_MB=2048
DICOM_3D_RENDER_TIMEOUT_SECONDS=30
DICOM_3D_CACHE_TTL_SECONDS=3600

# Phase 9: OpenTelemetry (distributed tracing)
# Requires the observability profile: `docker compose --profile observability up -d`
OTEL_ENABLED=true
OTEL_SERVICE_NAME=medinsight
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_DEPLOYMENT_ENVIRONMENT=production

# Phase 9: WebSocket (real-time notifications)
WEBSOCKET_ENABLED=true
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_AUTH_TIMEOUT=10

# Phase 5: Rate Limiting (Redis sliding window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=5
RATE_LIMIT_RESET_PER_HOUR=3

# Phase 5: Graceful Shutdown (seconds to drain in-flight requests)
GRACEFUL_SHUTDOWN_TIMEOUT=30

# Phase 5: App version (exposed via /health)
APP_VERSION=1.0.0

# Phase 6: Email (SMTP). Для Gmail используйте App Password (не обычный пароль).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@medinsight.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_ENABLED=true
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
EMAIL_PASSWORD_RESET_EXPIRE_HOURS=2
EMAIL_PREDICTION_READY_ENABLED=true
EMAIL_LIMIT_EXCEEDED_ENABLED=true
FRONTEND_URL=https://medinsight.fileguardian.info

# Phase 6: Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true
LOG_INCLUDE_REQUEST_ID=true
LOG_INCLUDE_USER_ID=true
LOG_SLOW_QUERY_MS=500
