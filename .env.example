SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./medinsight.db
# Docker (app + celery share this path via volume):
# DATABASE_URL=sqlite:////app/data/medinsight.db
STORAGE_PATH=./storage
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
SPACY_MODEL=ru_core_news_lg
APP_PORT=8000
# DOMAIN is used by Traefik (production) for the HTTPS router + Let's Encrypt cert
DOMAIN=fileguardian.com.ru
ACME_EMAIL=admin@fileguardian.com.ru

# Phase 2: Celery + GPT (ProxyAPI)
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
OPENAI_API_KEY=ваш_ключ_из_ProxyAPI
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Phase 3: Multi-tenancy + Encryption
TENANT_MODE=true
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=
ENCRYPTION_KEY_PATH=secrets/encryption_key.txt
SUPER_ADMIN_EMAIL=admin@medinsight.com
SUPER_ADMIN_PASSWORD=change_me_super_admin
DEFAULT_TENANT_NAME=Default Clinic
DEFAULT_TENANT_SUBDOMAIN=default

# Phase 4: Self-Healing RAG
SELF_HEALING_ENABLED=true
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.75
MAX_RETRY_ATTEMPTS=2

# Phase 4: Webhooks
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_SECONDS=2
WEBHOOK_FAILURE_DEACTIVATE_THRESHOLD=5
WEBHOOK_PUBLIC_BASE_URL=

# Phase 4: Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_ENTERPRISE=price_yyy
STRIPE_SUCCESS_URL=https://your-domain/payment/success
STRIPE_CANCEL_URL=https://your-domain/payment/cancel

# Phase 4: ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL_SUCCESS=https://your-domain/payment/success
YOOKASSA_RETURN_URL_CANCEL=https://your-domain/payment/cancel

# Phase 4: Plan limits + prices (kopecks for RUB, cents for USD)
FREEMIUM_ANALYSIS_LIMIT=5
PRO_ANALYSIS_LIMIT=100
ENTERPRISE_ANALYSIS_LIMIT=999999
PRO_PRICE_RUB=199000
PRO_PRICE_USD=1999
ENTERPRISE_PRICE_RUB=999000
ENTERPRISE_PRICE_USD=9999
